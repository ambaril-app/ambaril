# Database (Neon)
DATABASE_URL="postgresql://user:pass@host.neon.tech/ambaril?sslmode=require"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ─── Platform Infrastructure (OBRIGATÓRIO) ───────────────────────────────────
# Estes são serviços da plataforma Ambaril — NÃO são por tenant.

# Encryption key for tenant integration credentials stored in DB.
# Generate with: openssl rand -hex 32
# NEVER commit the real key. Never share across environments.
ENCRYPTION_KEY=""

# Cloudflare R2 (storage de assets — DAM, fotos de creators)
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="ambaril-assets"
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"
R2_PUBLIC_URL="https://assets.ambaril.app"

# Resend (email transacional da plataforma)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@ambaril.app"

# Auth
SESSION_SECRET=""
CREATOR_AUTH_SECRET=""
CRON_SECRET=""

# ─── Tenant Integrations ──────────────────────────────────────────────────────
# As credenciais de Shopify, Yever, Instagram, etc. NÃO vão aqui.
# Cada tenant configura suas integrações via /admin/settings/integrations.
# As credenciais são criptografadas com AES-256-GCM e salvas em global.tenant_integrations.
#
# Para conectar a CIENA após o primeiro login:
#   1. Acesse /admin/settings/integrations
#   2. Conecte Shopify (ecommerce) — shop domain + client ID + secret
#   3. Conecte Yever (checkout) — API URL + token
#   4. Conecte Instagram (social) — access token + business account ID
