# Database (Neon)
DATABASE_URL="postgresql://user:pass@host.neon.tech/ambaril?sslmode=require"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# --- Phase 1: Creators (OBRIGATÓRIO) ---

# Cloudflare R2 (upload de fotos de creators)
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="ambaril-assets"
R2_ENDPOINT="https://<account-id>.r2.cloudflarestorage.com"

# Resend (email transacional — confirmação de cadastro creator)
RESEND_API_KEY=""
RESEND_FROM_EMAIL="noreply@ciena.com.br"

# Shopify Admin API (sync cupons → discount codes)
# NOTA: Desde Jan 2026, Shopify usa OAuth Client Credentials (sem token permanente).
# O app gera tokens temporários (24h) a partir do client_id + client_secret.
SHOPIFY_STORE_URL="ciena-lab.myshopify.com"
SHOPIFY_CLIENT_ID=""
SHOPIFY_CLIENT_SECRET=""

# Yever API (atribuição de vendas por cupom)
YEVER_API_URL="https://api.yever.com.br/v1"
YEVER_API_KEY=""

# --- Phase 4+: Marketing Intel (OPCIONAL por agora) ---

# Instagram Graph API (UGC polling)
# INSTAGRAM_ACCESS_TOKEN=""
# INSTAGRAM_BUSINESS_ACCOUNT_ID=""
