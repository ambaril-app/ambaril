{
  "name": "ambaril",
  "version": "1.0.0",
  "private": true,
  "license": "UNLICENSED",
  "author": "boromarl",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo run test --filter='*'",
    "test:fast": "pnpm test:schemas && pnpm test:pbt",
    "test:schemas": "pnpm --filter @ambaril/shared test:schemas",
    "test:pbt": "pnpm --filter @ambaril/shared test:pbt && pnpm --filter @ambaril/web test:pbt",
    "test:integration": "pnpm --filter @ambaril/web test:integration",
    "test:e2e": "pnpm exec playwright test",
    "test:e2e:smoke": "pnpm exec playwright test e2e/smoke.spec.ts",
    "test:ci": "./bin/ci",
    "db:secure": "./bin/db-secure",
    "db:generate": "turbo db:generate",
    "db:migrate": "turbo db:migrate",
    "db:seed": "turbo db:seed",
    "shopify": "shopify",
    "shopify:dev": "shopify app dev",
    "shopify:build": "shopify app build",
    "shopify:deploy": "shopify app deploy",
    "spec:index": "bash scripts/build-state-index.sh",
    "spec:scan": "bash scripts/state-scan.sh",
    "spec:drift": "bash scripts/state-scan.sh drift --module",
    "skills:check": "scripts/sync-consumers.sh check",
    "skills:sync": "scripts/sync-consumers.sh all",
    "prepare": "husky"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "eslint-plugin-security": "^4.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "turbo": "^2",
    "typescript-eslint": "^8.58.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --quiet --max-warnings=0 --no-warn-ignored"
    ],
    "*.{ts,tsx,js,jsx,json,md}": [
      "prettier --check"
    ]
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "@node-rs/argon2"
    ],
    "overrides": {
      "lodash": ">=4.17.21"
    }
  }
}
